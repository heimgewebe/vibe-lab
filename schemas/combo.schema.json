{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/heimgewebe/vibe-lab/schemas/combo.schema.json",
  "title": "Combo Entry",
  "description": "Schema für Combo-Einträge (Kuratierte Synergien aus mehreren Practices). Operative Pipeline-Validierung.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Version dieses Schemas (semver)"
    },
    "title": {
      "type": "string",
      "description": "Name der Combo"
    },
    "status": {
      "type": "string",
      "enum": ["adopted", "deprecated"],
      "description": "Aktueller Status"
    },
    "summary": {
      "type": "string",
      "description": "Einzeilige Zusammenfassung"
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "practice": {
            "type": "string",
            "description": "Pfad zum referenzierten Katalogeintrag"
          },
          "role": {
            "type": "string",
            "description": "Rolle dieser Practice in der Combo"
          }
        },
        "required": ["practice"]
      },
      "minItems": 2,
      "description": "Mindestens zwei referenzierte Practices"
    },
    "evidence_source": {
      "type": "string",
      "description": "Pfad zum validierenden Experiment"
    },
    "synergy_description": {
      "type": "string",
      "description": "Warum diese Kombination mehr ist als die Summe ihrer Teile"
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "author": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["schema_version", "title", "status", "summary", "components", "evidence_source"]
}
