{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vibe-Lab Combo Recipe",
  "description": "Schema für Kombinationsrezepte im Vibe-Lab",
  "type": "object",
  "required": ["name", "style", "techniques", "tools", "difficulty", "tags"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Name der Kombination",
      "minLength": 1
    },
    "style": {
      "type": "string",
      "description": "Primärer Vibe-Coding-Stil (kebab-case ID)"
    },
    "techniques": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Verwendete Techniken (kebab-case IDs)"
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Verwendete Tools"
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced", "expert"],
      "description": "Schwierigkeitsgrad der Anwendung"
    },
    "best_for": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Am besten geeignet für diese Aufgabentypen"
    },
    "ratings": {
      "type": "object",
      "properties": {
        "speed": { "type": "integer", "minimum": 1, "maximum": 5 },
        "accuracy": { "type": "integer", "minimum": 1, "maximum": 5 },
        "code_quality": { "type": "integer", "minimum": 1, "maximum": 5 },
        "iterability": { "type": "integer", "minimum": 1, "maximum": 5 },
        "cognitive_load": { "type": "integer", "minimum": 1, "maximum": 5 },
        "scalability": { "type": "integer", "minimum": 1, "maximum": 5 },
        "creativity": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
