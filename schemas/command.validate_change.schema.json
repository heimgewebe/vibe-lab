{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/heimgewebe/vibe-lab/schemas/command.validate_change.schema.json",
  "title": "Command: validate_change (v0.1)",
  "description": "Minimal v0.1 schema for the conceptual command `validate_change`. Scope per Phase D of blueprint-agent-operability-phase-1c.md: only practically evidenced fields. checks[] is intentionally an open string list — not an enum — to avoid locking in check vocabulary before practical use confirms the right set. Recommended values per blueprint §C3: lint, test, docs-guard.",
  "type": "object",
  "properties": {
    "command": {
      "type": "string",
      "const": "validate_change"
    },
    "version": {
      "type": "string",
      "const": "v0.1"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "success": {
      "type": "boolean"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "required": ["command", "version", "checks", "success", "errors"],
  "allOf": [
    {
      "if": {
        "properties": { "success": { "const": true } },
        "required": ["success"]
      },
      "then": {
        "properties": {
          "errors": { "maxItems": 0 }
        }
      }
    },
    {
      "if": {
        "properties": { "success": { "const": false } },
        "required": ["success"]
      },
      "then": {
        "properties": {
          "errors": { "minItems": 1 }
        }
      }
    }
  ],
  "additionalProperties": true
}
