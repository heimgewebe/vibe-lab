{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/heimgewebe/vibe-lab/schemas/experiment.manifest.schema.json",
  "title": "Experiment Manifest",
  "description": "Schema für manifest.yml in Experiment-Ordnern. Operative Pipeline-Validierung (gehört in schemas/, nicht contracts/).",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Version dieses Schemas (semver)"
    },
    "experiment": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Kurzname des Experiments"
        },
        "hypothesis": {
          "type": "string",
          "description": "Zu prüfende Hypothese"
        },
        "status": {
          "type": "string",
          "enum": ["idea", "designed", "testing", "adopted", "rejected", "blocked", "inconclusive"],
          "description": "Aktueller Status des Experiments"
        },
        "cognitive_mode": {
          "type": "string",
          "enum": ["generative", "declarative", "executable", "exploratory"],
          "description": "Kognitiver Modus, in den das Modell durch den Prompt gezwungen wird"
        },
        "category": {
          "type": "string",
          "enum": ["style", "technology", "technique", "workflow", "combo"],
          "description": "Kategorie der untersuchten Praxis"
        },
        "created": {
          "type": "string",
          "format": "date",
          "description": "Startdatum des Experiments"
        },
        "updated": {
          "type": "string",
          "format": "date",
          "description": "Letztes Update"
        },
        "author": {
          "type": "string",
          "description": "Experimentverantwortliche Person"
        },
        "iteration": {
          "type": "integer",
          "minimum": 1,
          "description": "Aktuelle Iterationsnummer"
        },
        "execution_status": {
          "type": "string",
          "enum": ["designed", "prepared", "executed", "replicated", "reconstructed"],
          "description": "Durchführungsgrad (orthogonal zu status und evidence_level): designed (nur Entwurf), prepared (Setup angelegt, kein Run), executed (tatsächlicher Run mit Spur in execution_refs), replicated (belastbar und unabhängig wiederholt), reconstructed (historische Einstufung — Experiment fand statt, aber ohne erfassten Execution-Proof; nur für Altbestand zulässig, gem. docs/concepts/execution-bound-epistemics.md §11.1)"
        },
        "execution_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Spurverweise, insbesondere bei executed/replicated: Pfade zu evidence.jsonl, Artefakten, Logs oder Ergebnisdateien. Bei execution_status designed oder prepared sollte dieses Feld in der Regel leer bleiben."
        },
        "evidence_level": {
          "type": "string",
          "enum": ["anecdotal", "experimental", "replicated"],
          "description": "Epistemisches Niveau der Evidenz: anecdotal (einzelne Beobachtung), experimental (kontrollierter Test), replicated (unabhängig reproduziert)"
        },
        "replicated_from": {
          "type": "string",
          "description": "Pfad zum Original-Experiment bei Replikation"
        },
        "adoption_basis": {
          "type": "string",
          "enum": ["executed", "replicated", "reconstructed"],
          "description": "Execution-Grundlage, auf der eine Adoption fußt. Pflicht bei status: adopted. 'reconstructed' kennzeichnet historische Adoptionen ohne erfassten Execution-Proof (nur für Altbestand zulässig); siehe docs/blueprints/blueprint-v2.md Übergangsregel."
        },
        "related_idea": {
          "type": "string",
          "description": "Referenz auf Idea-Issue (z.B. #42)"
        },
        "falsifiability": {
          "type": "object",
          "description": "Falsifizierbarkeitsstruktur (Promotion-Readiness Dry-Run Gate, Phase 1). Genau eines von zwei Formaten muss verwendet werden: Legacy-Format (counter_hypothesis + falsification_criterion + counterevidence_checked) oder Structured-Format v1 (version=1 + falsification_criterion + counter_hypotheses[]). Hybride Blöcke und lose Blöcke (z. B. {version: 1} ohne counter_hypotheses) sind ungültig. Semantik-Gate in validate_promotion_readiness.py. Leitthese: Bestätigung verteuern, nicht Wahrheit quantifizieren.",
          "oneOf": [
            {
              "title": "Legacy-Format",
              "description": "Rückwärtskompatibles Format: counter_hypothesis + falsification_criterion + counterevidence_checked. Für neue Manifeste Structured-Format v1 verwenden.",
              "required": ["counter_hypothesis", "falsification_criterion", "counterevidence_checked"],
              "additionalProperties": false,
              "properties": {
                "counter_hypothesis": {
                  "type": "string",
                  "minLength": 10,
                  "description": "Alternativerklärung, die die beobachteten Effekte ebenfalls erklären könnte."
                },
                "falsification_criterion": {
                  "type": "string",
                  "minLength": 10,
                  "description": "Operationale Bedingung, unter der die Hypothese als widerlegt oder geschwächt gelten würde."
                },
                "counterevidence_checked": {
                  "type": "boolean",
                  "description": "Wurde aktiv nach Gegenevidenz gesucht? Decision-Kreuzregel in validate_schema.py prüft verdict=confirms + counterevidence_checked=false in decision.yml."
                }
              }
            },
            {
              "title": "Structured-Format v1",
              "description": "Strukturiertes Format mit separaten Gegenhypothesen und maschinenlesbarem Assessment-Zustand.",
              "required": ["version", "falsification_criterion", "counter_hypotheses"],
              "additionalProperties": false,
              "properties": {
                "version": {
                  "type": "integer",
                  "const": 1,
                  "description": "Muss 1 sein. Zukünftige Versionen erhalten eigene Einträge."
                },
                "falsification_criterion": {
                  "type": "string",
                  "minLength": 10,
                  "description": "Operationale Bedingung, unter der die Haupthypothese als widerlegt oder geschwächt gelten würde."
                },
                "counter_hypotheses": {
                  "type": "array",
                  "minItems": 1,
                  "description": "Nicht-leere Liste von Gegenhypothesen mit Bewertungsstruktur.",
                  "items": {
                    "type": "object",
                    "required": ["id", "statement", "assessment"],
                    "additionalProperties": false,
                    "properties": {
                      "id": {
                        "type": "string",
                        "minLength": 1,
                        "description": "Stabiler Slug der Gegenhypothese (z. B. 'ceiling_effect')"
                      },
                      "statement": {
                        "type": "string",
                        "minLength": 10,
                        "description": "Vollständige Formulierung der Gegenhypothese"
                      },
                      "assessment": {
                        "type": "object",
                        "required": ["status", "outcome"],
                        "additionalProperties": false,
                        "description": "Bewertungsstand für diese Gegenhypothese",
                        "properties": {
                          "status": {
                            "type": "string",
                            "enum": ["documented", "pending", "partially_checked", "checked", "blocked", "not_applicable"],
                            "description": "documented/pending: noch nicht geprüft; partially_checked: Prüfung begonnen; checked: abgeschlossen; blocked: nicht möglich; not_applicable: nicht relevant"
                          },
                          "outcome": {
                            "type": "string",
                            "enum": ["not_checked", "inconclusive", "supports_primary", "supports_counterhypothesis", "mixed", "not_applicable"],
                            "description": "Ergebnis: supports_primary stärkt Haupthypothese; supports_counterhypothesis widerlegt sie; inconclusive/mixed: keine klare Richtung"
                          },
                          "evidence_refs": {
                            "type": "array",
                            "description": "Verweise auf Evidenzdateien, die die Bewertung stützen",
                            "items": {
                              "type": "object",
                              "required": ["path"],
                              "additionalProperties": false,
                              "properties": {
                                "path": {
                                  "type": "string",
                                  "minLength": 1,
                                  "description": "Repo-relativer Pfad zur Evidenzdatei"
                                },
                                "section": {
                                  "type": "string",
                                  "description": "Optionaler Abschnitt oder Überschrift in der Datei"
                                }
                              }
                            }
                          },
                          "pending_checks": {
                            "type": "array",
                            "items": { "type": "string", "minLength": 1 },
                            "description": "Ausstehende Prüfschritte"
                          },
                          "limitations": {
                            "type": "array",
                            "items": { "type": "string", "minLength": 1 },
                            "description": "Residuale Einschränkungen oder Confounder"
                          },
                          "confidence": {
                            "type": "string",
                            "enum": ["low", "medium", "high"],
                            "description": "Konfidenz in die Bewertung"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          ]
        }
      },
      "required": ["name", "hypothesis", "status", "category", "evidence_level"],
      "allOf": [
        {
          "if": {
            "properties": { "evidence_level": { "const": "replicated" } }
          },
          "then": {
            "required": ["replicated_from", "execution_status"],
            "properties": {
              "replicated_from": {
                "type": "string",
                "minLength": 1
              },
              "execution_status": {
                "not": { "enum": ["designed", "prepared"] }
              }
            }
          }
        },
        {
          "if": {
            "required": ["execution_status"],
            "properties": { "execution_status": { "enum": ["executed", "replicated"] } }
          },
          "then": {
            "required": ["execution_refs"],
            "properties": {
              "execution_refs": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": { "status": { "const": "adopted" } },
            "required": ["status"]
          },
          "then": {
            "required": ["adoption_basis"]
          }
        },
        {
          "if": {
            "required": ["adoption_basis"],
            "properties": { "adoption_basis": { "const": "executed" } }
          },
          "then": {
            "required": ["execution_status"],
            "properties": {
              "execution_status": { "const": "executed" }
            }
          }
        },
        {
          "if": {
            "required": ["adoption_basis"],
            "properties": { "adoption_basis": { "const": "replicated" } }
          },
          "then": {
            "required": ["execution_status"],
            "properties": {
              "execution_status": { "const": "replicated" }
            }
          }
        },
        {
          "if": {
            "required": ["adoption_basis"],
            "properties": { "adoption_basis": { "const": "reconstructed" } }
          },
          "then": {
            "required": ["execution_status"],
            "properties": {
              "execution_status": { "const": "reconstructed" }
            }
          }
        }
      ]
    },
    "context": {
      "type": "object",
      "properties": {
        "tools": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Verwendete Tools und Modelle"
        },
        "language": {
          "type": "string",
          "description": "Primäre Programmiersprache"
        },
        "environment": {
          "type": "string",
          "description": "Entwicklungsumgebung"
        }
      }
    },
    "evidence": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string",
          "const": "jsonl",
          "description": "Format der Evidenzdaten"
        },
        "path": {
          "type": "string",
          "description": "Relativer Pfad zur Evidenzdatei"
        }
      }
    }
  },
  "required": ["schema_version", "experiment"]
}
