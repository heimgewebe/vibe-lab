{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/heimgewebe/vibe-lab/schemas/experiment.manifest.schema.json",
  "title": "Experiment Manifest",
  "description": "Schema für manifest.yml in Experiment-Ordnern. Operative Pipeline-Validierung (gehört in schemas/, nicht contracts/).",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Version dieses Schemas (semver)"
    },
    "experiment": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Kurzname des Experiments"
        },
        "hypothesis": {
          "type": "string",
          "description": "Zu prüfende Hypothese"
        },
        "status": {
          "type": "string",
          "enum": ["idea", "designed", "testing", "adopted", "rejected", "blocked", "inconclusive"],
          "description": "Aktueller Status des Experiments"
        },
        "cognitive_mode": {
          "type": "string",
          "enum": ["generative", "declarative", "executable", "exploratory"],
          "description": "Kognitiver Modus, in den das Modell durch den Prompt gezwungen wird"
        },
        "category": {
          "type": "string",
          "enum": ["style", "technology", "technique", "workflow", "combo"],
          "description": "Kategorie der untersuchten Praxis"
        },
        "created": {
          "type": "string",
          "format": "date",
          "description": "Startdatum des Experiments"
        },
        "updated": {
          "type": "string",
          "format": "date",
          "description": "Letztes Update"
        },
        "author": {
          "type": "string",
          "description": "Experimentverantwortliche Person"
        },
        "iteration": {
          "type": "integer",
          "minimum": 1,
          "description": "Aktuelle Iterationsnummer"
        },
        "execution_status": {
          "type": "string",
          "enum": ["designed", "prepared", "executed", "replicated", "reconstructed"],
          "description": "Durchführungsgrad (orthogonal zu status und evidence_level): designed (nur Entwurf), prepared (Setup angelegt, kein Run), executed (tatsächlicher Run mit Spur in execution_refs), replicated (belastbar und unabhängig wiederholt), reconstructed (historische Einstufung — Experiment fand statt, aber ohne erfassten Execution-Proof; nur für Altbestand zulässig, gem. docs/concepts/execution-bound-epistemics.md §11.1)"
        },
        "execution_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Spurverweise, insbesondere bei executed/replicated: Pfade zu evidence.jsonl, Artefakten, Logs oder Ergebnisdateien. Bei execution_status designed oder prepared sollte dieses Feld in der Regel leer bleiben."
        },
        "evidence_level": {
          "type": "string",
          "enum": ["anecdotal", "experimental", "replicated"],
          "description": "Epistemisches Niveau der Evidenz: anecdotal (einzelne Beobachtung), experimental (kontrollierter Test), replicated (unabhängig reproduziert)"
        },
        "replicated_from": {
          "type": "string",
          "description": "Pfad zum Original-Experiment bei Replikation"
        },
        "adoption_basis": {
          "type": "string",
          "enum": ["executed", "replicated", "reconstructed"],
          "description": "Execution-Grundlage, auf der eine Adoption fußt. Pflicht bei status: adopted. 'reconstructed' kennzeichnet historische Adoptionen ohne erfassten Execution-Proof (nur für Altbestand zulässig); siehe docs/blueprints/blueprint-v2.md Übergangsregel."
        },
        "related_idea": {
          "type": "string",
          "description": "Referenz auf Idea-Issue (z.B. #42)"
        },
        "falsifiability": {
          "type": "object",
          "description": "Falsifizierbarkeitsstruktur (Promotion-Readiness Dry-Run Gate, Phase 1). Akzeptiert Legacy-Format (counter_hypothesis + falsification_criterion + counterevidence_checked) und strukturiertes Format v1 (version=1 + falsification_criterion + counter_hypotheses[]). Semantik-Gate ausschließlich in scripts/docmeta/validate_promotion_readiness.py — nicht in diesem JSON-Schema hart erzwungen. historical_escape (adoption_basis=reconstructed) bleibt als Ausnahme; Leitthese: Bestätigung verteuern, nicht Wahrheit quantifizieren.",
          "properties": {
            "version": {
              "type": "integer",
              "const": 1,
              "description": "Structured-Format-Version. Wenn vorhanden, wird das structured (v1) Evaluierungsprotokoll angewandt."
            },
            "counter_hypothesis": {
              "type": "string",
              "minLength": 10,
              "description": "LEGACY: Einzelne Gegenhypothesen-Zeichenkette. Für neue Manifeste counter_hypotheses[] verwenden."
            },
            "falsification_criterion": {
              "type": "string",
              "minLength": 10,
              "description": "Operationale Bedingung, unter der die Hypothese als widerlegt oder geschwächt gelten würde. Pflicht in Legacy- und Structured-Format."
            },
            "counterevidence_checked": {
              "type": "boolean",
              "description": "LEGACY: Boolean-Feld. Für neue Manifeste structured counter_hypotheses[].assessment verwenden. Semantik: wurde aktiv nach Gegenevidenz gesucht? Die Decision-Kreuzregel in scripts/docmeta/validate_schema.py prüft nur verdict=confirms + counterevidence_checked=false in decision.yml."
            },
            "counter_hypotheses": {
              "type": "array",
              "description": "Structured-Format v1: Liste von Gegenhypothesen mit Bewertungsstruktur. Semantik-Gate in validate_promotion_readiness.py.",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Stabiler Slug der Gegenhypothese (z. B. 'ceiling_effect', 'executor_bias')"
                  },
                  "statement": {
                    "type": "string",
                    "minLength": 10,
                    "description": "Vollständige Formulierung der Gegenhypothese"
                  },
                  "assessment": {
                    "type": "object",
                    "description": "Bewertungsstand für diese Gegenhypothese",
                    "properties": {
                      "status": {
                        "type": "string",
                        "enum": ["documented", "pending", "partially_checked", "checked", "blocked", "not_applicable"],
                        "description": "documented/pending: noch nicht geprüft; partially_checked: Prüfung begonnen; checked: Prüfung abgeschlossen; blocked: Prüfung nicht möglich; not_applicable: Hypothese nicht relevant"
                      },
                      "outcome": {
                        "type": "string",
                        "enum": ["not_checked", "inconclusive", "supports_primary", "supports_counterhypothesis", "mixed", "not_applicable"],
                        "description": "Ergebnis der Prüfung: supports_primary stärkt die Haupthypothese; supports_counterhypothesis widerlegt sie; inconclusive/mixed: keine klare Richtung; not_checked: noch nicht geprüft; not_applicable: Outcome nicht bestimmbar"
                      },
                      "evidence_refs": {
                        "type": "array",
                        "description": "Verweise auf Evidenzdateien, die die Bewertung stützen",
                        "items": {
                          "type": "object",
                          "properties": {
                            "path": {
                              "type": "string",
                              "description": "Repo-relativer Pfad zur Evidenzdatei"
                            },
                            "section": {
                              "type": "string",
                              "description": "Optionaler Abschnitt oder Überschrift in der Datei"
                            }
                          }
                        }
                      },
                      "pending_checks": {
                        "type": "array",
                        "items": { "type": "string" },
                        "description": "Ausstehende Prüfschritte, die noch durchgeführt werden müssen"
                      },
                      "limitations": {
                        "type": "array",
                        "items": { "type": "string" },
                        "description": "Residuale Einschränkungen oder Confounder, die nach Abschluss der Prüfung verbleiben"
                      },
                      "confidence": {
                        "type": "string",
                        "enum": ["low", "medium", "high"],
                        "description": "Konfidenz in die Bewertung"
                      }
                    },
                    "required": ["status", "outcome"]
                  }
                },
                "required": ["id", "statement", "assessment"]
              }
            }
          }
        }
      },
      "required": ["name", "hypothesis", "status", "category", "evidence_level"],
      "allOf": [
        {
          "if": {
            "properties": { "evidence_level": { "const": "replicated" } }
          },
          "then": {
            "required": ["replicated_from", "execution_status"],
            "properties": {
              "replicated_from": {
                "type": "string",
                "minLength": 1
              },
              "execution_status": {
                "not": { "enum": ["designed", "prepared"] }
              }
            }
          }
        },
        {
          "if": {
            "required": ["execution_status"],
            "properties": { "execution_status": { "enum": ["executed", "replicated"] } }
          },
          "then": {
            "required": ["execution_refs"],
            "properties": {
              "execution_refs": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": { "status": { "const": "adopted" } },
            "required": ["status"]
          },
          "then": {
            "required": ["adoption_basis"]
          }
        },
        {
          "if": {
            "required": ["adoption_basis"],
            "properties": { "adoption_basis": { "const": "executed" } }
          },
          "then": {
            "required": ["execution_status"],
            "properties": {
              "execution_status": { "const": "executed" }
            }
          }
        },
        {
          "if": {
            "required": ["adoption_basis"],
            "properties": { "adoption_basis": { "const": "replicated" } }
          },
          "then": {
            "required": ["execution_status"],
            "properties": {
              "execution_status": { "const": "replicated" }
            }
          }
        },
        {
          "if": {
            "required": ["adoption_basis"],
            "properties": { "adoption_basis": { "const": "reconstructed" } }
          },
          "then": {
            "required": ["execution_status"],
            "properties": {
              "execution_status": { "const": "reconstructed" }
            }
          }
        }
      ]
    },
    "context": {
      "type": "object",
      "properties": {
        "tools": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Verwendete Tools und Modelle"
        },
        "language": {
          "type": "string",
          "description": "Primäre Programmiersprache"
        },
        "environment": {
          "type": "string",
          "description": "Entwicklungsumgebung"
        }
      }
    },
    "evidence": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string",
          "const": "jsonl",
          "description": "Format der Evidenzdaten"
        },
        "path": {
          "type": "string",
          "description": "Relativer Pfad zur Evidenzdatei"
        }
      }
    }
  },
  "required": ["schema_version", "experiment"]
}
